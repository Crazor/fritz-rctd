# Copy to .env and fill in real values.
# .env itself is in .gitignore - do not commit it.
#
# The native helper does NOT load a .env file itself (only real
# environment variables) - load it before invoking, e.g.:
#   set -a && source .env && set +a
#   build/fritz-rctd --own '**621' --target 004912345678

FRITZ_RCTD_SIP_DOMAIN=192.168.178.1
FRITZ_RCTD_SIP_USERNAME=
FRITZ_RCTD_SIP_PASSWORD=

# Optional, defaults: see README or --help:
# FRITZ_RCTD_SIP_PORT=5060
# FRITZ_RCTD_OWN_TIMEOUT_SEC=30
# FRITZ_RCTD_TARGET_TIMEOUT_SEC=30
# FRITZ_RCTD_TRANSFER_TIMEOUT_SEC=10
# FRITZ_RCTD_REG_TIMEOUT_SEC=10
# FRITZ_RCTD_LOG_LEVEL=3
